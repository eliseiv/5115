# =============================================================================
# novirell instance env template — server 49.12.189.77, SHARED nginx edge (mas-nginx),
# NOT Traefik. Copy to /opt/novirell/.env ON THE SERVER and fill every <SET_ME> /
# <GENERATE...> from the secret manager. NEVER commit the real .env (it is gitignored).
# This .example holds PLACEHOLDERS ONLY — no real secrets.
#
# Differs from .env.prod.example (the legacy Traefik server) in the edge wiring:
#   EDGE_NETWORK=mas-net, TRUSTED_PROXY_IPS=<mas-net subnet>, COMPOSE_PROJECT_NAME=novirell.
# Loaded by docker-compose.prod.yml via `env_file: .env` (api + migrate). Image is BUILT ON THE
# SERVER (no registry tag). Generate high-entropy secrets with:  openssl rand -base64 32
# =============================================================================

# --- Instance identity / edge wiring (novirell) ------------------------------
# COMPOSE_PROJECT_NAME is REQUIRED here (unlike the legacy live instance which leaves it unset):
# it fixes the compose project to `novirell`, giving the deterministic container name
# `novirell-api-1` that the nginx vhost (deploy/nginx/novirell.shop.conf) proxies to. Deploy also
# passes `-p novirell`; both agree so `-p` and this env yield the same project name.
COMPOSE_PROJECT_NAME=novirell
# External edge docker network. On THIS server the shared reverse proxy is `mas-nginx`, a member of
# the pre-existing external network `mas-net` (owned by the mail-aggregator stack). Our container
# joins mas-net so mas-nginx can reach it by name. docker-compose.prod.yml maps compose network
# `web` -> name ${EDGE_NETWORK:-web}. We do NOT create mas-net (external: true, already exists).
EDGE_NETWORK=mas-net
# Service domain — DUAL role: (1) read by the APP (ADR-031) to build the ABSOLUTE site.preview URL
# https://novirell.shop/v1/preview/...; (2) informational for the ops runbook. TLS is terminated by
# mas-nginx (host certbot cert), NOT by the app. A-record novirell.shop -> 49.12.189.77 already set.
SERVICE_DOMAIN=novirell.shop
# TRAEFIK_CERTRESOLVER — NOT used on this server (no Traefik). BUT docker-compose.prod.yml declares
# the label with `${TRAEFIK_CERTRESOLVER:?...}`, so `docker compose config`/`up` FAILS if it is
# unset. Set a harmless placeholder `le`: the resulting traefik.* label is inert here (mas-nginx
# does not read docker labels — it routes via the docker-cp'd vhost). Keeps the shared compose file
# backward-compatible without a novirell-specific fork.
TRAEFIK_CERTRESOLVER=le

# --- Database / Redis --------------------------------------------------------
# In-compose service names on the internal `default` network. DATABASE_URL is assembled from the
# three POSTGRES_* values IN FULL — all three must match the URL. Use a FRESH password (never reuse
# another instance's DB or credentials); volumes are isolated per project name (novirell_pgdata).
DATABASE_URL=postgresql+asyncpg://<db_user>:<db_password>@postgres:5432/<db_name>
REDIS_URL=redis://redis:6379/0
POSTGRES_USER=<db_user>
POSTGRES_PASSWORD=<GENERATE: openssl rand -base64 32>
POSTGRES_DB=<db_name>

# --- LLM provider selection (ADR-033) — novirell is an OpenAI instance -------
# openai activates the OpenAI orchestration path (chat + dialog modes + image generation).
LLM_PROVIDER=openai

# --- OpenAI (mode=credits). REQUIRED when LLM_PROVIDER=openai (ADR-033). ------
# OPENAI_API_KEY — SECRET, secret manager only, under redaction. Own key WITH positive balance;
# never share across instances. NEVER commit a real value.
OPENAI_API_KEY=<SET_ME>
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=16000
OPENAI_TIMEOUT_SECONDS=120
OPENAI_MAX_RETRIES=2
# Active model reported in the BYOK response (activeModel) for an OpenAI BYOK key.
OPENAI_BYOK_DEFAULT_MODEL=gpt-4o
# Anthropic BYOK default model — applies to an Anthropic key a user may bring even on this
# OpenAI instance (multi-provider BYOK, ADR-044). Not a secret.
BYOK_DEFAULT_MODEL=claude-sonnet-4-6

# --- Dialog modes + image generation (ADR-055/ADR-058/ADR-059) — OpenAI ------
# Deep Thinking: reasoning model FORCED by dialogMode=deep_thinking. Effort low|medium|high.
DEEP_THINKING_MODEL=o4-mini
DEEP_THINKING_EFFORT=medium
DEEP_THINKING_TIMEOUT_SECONDS=180
# Search: search_context_size of the built-in web_search tool; low|medium|high.
OPENAI_SEARCH_CONTEXT_SIZE=medium
# Image generation (ADR-058): gpt-image-1 via a separate images.generate client, key-gated on
# OPENAI_API_KEY. IMAGE_CREDITS_COST is a separate per-image debit on top of the 1-credit turn.
IMAGE_CREDITS_COST=5
IMAGE_MODEL=gpt-image-1
IMAGE_DEFAULT_SIZE=1024x1024
IMAGE_DEFAULT_QUALITY=high
IMAGE_OUTPUT_FORMAT=png
IMAGE_TIMEOUT_SECONDS=120
IMAGE_MAX_RETRIES=2
IMAGE_MAX_BYTES=16777216
TEMPORARY_IMAGE_TTL_SECONDS=86400
IMAGE_SWEEP_BATCH_SIZE=100
IMAGE_SWEEP_MIN_INTERVAL_SECONDS=300

# --- JWT (RS256) — embedded issuer (ADR-018) ---------------------------------
# Generate a FRESH RSA keypair ON THE SERVER into /opt/novirell/.secrets/ (see the provisioning
# runbook at the bottom) and point the *_PATH vars at the mounted files. Without a private key
# /v1/auth/* returns 503 (verify still works).
JWT_ISSUER=https://novirell.shop
JWT_AUDIENCE=claude-ios
JWT_KID=novirell-key-1
JWT_PRIVATE_KEY_PATH=/app/.secrets/jwt_private.pem
JWT_PUBLIC_KEY_PATH=/app/.secrets/jwt_public.pem
# Inline PEM alternative (\n-escaped); leave empty when using *_PATH.
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_JWKS_URL=
AUTH_ACCESS_TTL_SECONDS=3600
AUTH_REFRESH_TTL_SECONDS=2592000
AUTH_RATE_LIMIT_PER_IP=10

# --- KMS envelope encryption for BYOK (ADR-003, LocalKmsClient on MVP) --------
# High-entropy 32-byte master key, base64. SECRET. KMS_KEY_ID stays empty on MVP.
KMS_KEY_ID=
KMS_LOCAL_MASTER_KEY=<GENERATE: openssl rand -base64 32>

# --- Trusted reverse-proxy = the shared nginx (mas-nginx) --------------------
# CRITICAL: mas-nginx sets X-Forwarded-For; without trusting the mas-net subnet the per-IP rate
# limit would see mas-nginx's IP (172.18.0.7) instead of the real client and be effectively global.
# mas-net is a default docker bridge network -> /16. Parsed as CSV CIDR via
# ipaddress.ip_network(strict=False) in config.py (172.18.0.0/16 is valid). Verify on the server:
#   docker network inspect mas-net --format '{{range .IPAM.Config}}{{.Subnet}}{{end}}'
#
# TRADE-OFF (accepted, tech-debt TD-037): the whole /16 is trusted, not just mas-nginx's /32. Any
# OTHER container on the shared mas-net (e.g. a compromised mail-aggregator container) could reach
# novirell-api-1:8000 DIRECTLY (bypassing nginx); its peer IP would fall inside the trusted /16, so
# its X-Forwarded-For would be honoured -> client_ip spoofable for that in-network attacker. A /32
# pin was rejected: mas-nginx's IP (172.18.0.7) is NOT reserved and changes on container recreate,
# which would silently break client_ip resolution (untrusted peer -> config.py returns the socket
# peer, i.e. mas-nginx, making per-IP limiting global — a SILENT degradation). Residual risk is
# bounded (in-mas-net attacker only; the public edge path is already hardened by the XFF overwrite
# in deploy/nginx/novirell.shop.conf). See docs/07-deployment.md §Сервер novirell + TD-037.
TRUSTED_PROXY_IPS=172.18.0.0/16
TRUSTED_PROXY_HOP_COUNT=1

# --- Process manager (RAM-constrained host) ----------------------------------
# gunicorn worker count. Dockerfile default is 4; this server shares 3.8 GB RAM with the
# mail-aggregator stack, so run 2 (see docs/07-deployment.md RAM note). Consumed by the Dockerfile
# CMD (sh -c ... -w ${GUNICORN_WORKERS:-4}), NOT by the app config. DB-pool recompute below.
GUNICORN_WORKERS=2

# --- Admin auth (ADR-009) — SECRET, isolated, high-entropy -------------------
ADMIN_API_SECRET=<GENERATE: openssl rand -base64 32>
ADMIN_API_SECRET_PREV=
ADMIN_RATE_LIMIT_PER_MIN=10
ADMIN_SIZE_LIMIT_BODY=8192

# --- Website builder / preview (ADR-010) — SECRET, isolated HMAC key ---------
PREVIEW_URL_SECRET=<GENERATE: openssl rand -base64 32>
PREVIEW_URL_TTL_SECONDS=900
PREVIEW_MAX_FILE_BYTES=1048576
PREVIEW_MAX_PROJECT_BYTES=10485760
PREVIEW_MAX_FILES=200
MAX_SERVER_TOOL_ROUNDS=16

# --- App Store / StoreKit — test-mode on MVP (real Apple certs post-launch) ---
APPSTORE_ENVIRONMENT=production
APPSTORE_BUNDLE_ID=<com.example.app>
APPSTORE_ROOT_CERT_DIR=/etc/appstore-certs
STOREKIT_TEST_MODE=false
STOREKIT_TEST_SECRET=

# --- Billing (ADR-006 / ADR-015 / ADR-029) -----------------------------------
SUBSCRIPTION_CREDITS_PER_PERIOD=1000
TOKEN_PRODUCTS={"tokens_1500":1500,"tokens_600":600,"tokens_250":250,"tokens_100":100}
# Adapty subscription webhook — SECRET; empty => POST /v1/billing/adapty/webhook returns 500.
ADAPTY_WEBHOOK_SECRET=<GENERATE: openssl rand -hex 32; also set in Adapty UI>
ADAPTY_PRODUCT_TOKENS={"weekly_xxx":1000,"yearly_yyy":1000}
ADAPTY_SUBSCRIPTION_TOKENS_GRANT=1000

# --- DB connection pool (per process) ----------------------------------------
# Effective conns ~= (DB_POOL_SIZE + DB_MAX_OVERFLOW) * GUNICORN_WORKERS(2) * replicas(1)
# = (10 + 5) * 2 * 1 = 30 < Postgres max_connections (100) — comfortable headroom. If you raise
# GUNICORN_WORKERS, recompute: keep (DB_POOL_SIZE+DB_MAX_OVERFLOW)*workers < max_connections.
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=5
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# --- API documentation — hide schema in prod --------------------------------
DOCS_ENABLED=false

# --- Observability -----------------------------------------------------------
LOG_LEVEL=INFO
OTEL_EXPORTER_OTLP_ENDPOINT=
# SECRET: if set, GET /metrics requires X-Scrape-Token == this value (else 403).
METRICS_SCRAPE_TOKEN=<GENERATE: openssl rand -base64 32>

# =============================================================================
# novirell provisioning runbook (operator, ON THE SERVER 49.12.189.77, root).
# Full step-by-step is in docs/07-deployment.md §Сервер novirell — provisioning runbook.
#   1. mkdir -p /opt/novirell && git clone <repo> /opt/novirell && cd /opt/novirell
#   2. cp deploy/novirell.env.example .env   # then fill every <SET_ME>/<GENERATE...>
#   3. Fresh RSA keypair into /opt/novirell/.secrets/ (jwt_private.pem + jwt_public.pem),
#      chown 10001:10001, chmod 640 (matches the container's non-root uid).
#   4. Deliver the vhost to the shared nginx:
#        docker cp deploy/nginx/novirell.shop.conf mas-nginx:/etc/nginx/conf.d/novirell.shop.conf
#        docker exec mas-nginx nginx -t && docker exec mas-nginx nginx -s reload
#      (also keep a durability copy in /opt/mail-agregator/deploy/nginx/templates/).
#   5. Bring up the stack (build -> migrate -> up -> readiness):
#        docker compose -p novirell -f docker-compose.prod.yml --env-file .env build api migrate
#        docker compose -p novirell -f docker-compose.prod.yml --env-file .env run --rm migrate
#        docker compose -p novirell -f docker-compose.prod.yml --env-file .env up -d --no-build
#   6. Verify: docker inspect novirell-api-1 --format '{{.State.Health.Status}}' -> healthy;
#      curl -fsS https://novirell.shop/healthz -> 200.
# NEVER store real secrets in the repo or image. Use a FRESH value for every <GENERATE...>.
# =============================================================================
